# Local development (Supabase local Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DATABASE_URL_DEV=postgresql://postgres:postgres@localhost:54322/postgres

# Production database URL (set when available)
DATABASE_URL_PROD=

# Supabase Auth client vars
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional local-dev overrides (used in NODE_ENV != production to bypass shell-exported remote vars)
NEXT_PUBLIC_SUPABASE_URL_LOCAL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY_LOCAL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY_LOCAL=
NEXT_PUBLIC_ENABLE_LOCAL_AUTH_HELPERS=true

# Supabase service-role key — used SERVER-SIDE ONLY for Storage operations.
# Never expose this to the browser. Get it from: supabase status (local) or
# the Supabase Dashboard → Project Settings → API → service_role key (prod).
SUPABASE_SERVICE_ROLE_KEY=

# MassHealth forms extraction service
NEXT_PUBLIC_MASSHEALTH_FORMS_BASE_URL=http://localhost:8000

# MassHealth analysis service (extract/auto — masshealth-analysis)
NEXT_PUBLIC_MASSHEALTH_ANALYSIS_BASE_URL=http://localhost:8000

# Local Ollama chat config (MassHealth assistant)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Reverse proxy / production domain
DOMAIN=yourdomain.com
ACME_EMAIL=you@yourdomain.com   # used by Traefik to register Let's Encrypt certs
