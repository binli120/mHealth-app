# Local development (Supabase local Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DATABASE_URL_DEV=postgresql://postgres:postgres@localhost:54322/postgres

# Production database URL (set when available)
DATABASE_URL_PROD=

# Supabase Auth client vars
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional local-dev overrides (used in NODE_ENV != production to bypass shell-exported remote vars)
NEXT_PUBLIC_SUPABASE_URL_LOCAL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY_LOCAL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY_LOCAL=
NEXT_PUBLIC_ENABLE_LOCAL_AUTH_HELPERS=true

# Supabase service-role key — used SERVER-SIDE ONLY for Storage operations.
# Never expose this to the browser. Get it from: supabase status (local) or
# the Supabase Dashboard → Project Settings → API → service_role key (prod).
SUPABASE_SERVICE_ROLE_KEY=

# MassHealth forms extraction service
NEXT_PUBLIC_MASSHEALTH_FORMS_BASE_URL=http://localhost:8000

# MassHealth analysis service (extract/auto — masshealth-analysis)
NEXT_PUBLIC_MASSHEALTH_ANALYSIS_BASE_URL=http://localhost:8000

# Local Ollama chat config (MassHealth assistant)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ── OpenObserve observability ─────────────────────────────────────────────────
# Leave blank to disable; all three must be set to activate log shipping + tracing.
# Point at your Hostinger OpenObserve instance, e.g. http://your-server-ip:5080
OPENOBSERVE_URL=
OPENOBSERVE_USER=admin@example.com
OPENOBSERVE_PASSWORD=
# Optional — defaults shown:
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=mhealth_app
OPENOBSERVE_STREAM_CONTAINERS=containers_prod
OPENOBSERVE_METRICS_INTERVAL_MS=60000

# Health check sidecar (internal Docker service — only needed in production)
HEALTHCHECK_SIDECAR_URL=http://healthcheck:4000

# Browser RUM + frontend logs. For production HTTPS pages, prefer an HTTPS
# OpenObserve endpoint (for example observe.healthcompass.cloud) over raw :5080.
NEXT_PUBLIC_OPENOBSERVE_RUM_ENABLED=false
NEXT_PUBLIC_OPENOBSERVE_RUM_CLIENT_TOKEN=rum0yUTEgT6HU0fNSbJ
NEXT_PUBLIC_OPENOBSERVE_RUM_APPLICATION_ID=healthcompass-web
NEXT_PUBLIC_OPENOBSERVE_RUM_SITE=observe.healthcompass.cloud
NEXT_PUBLIC_OPENOBSERVE_RUM_SERVICE=healthcompass-web
NEXT_PUBLIC_OPENOBSERVE_RUM_ENV=production
NEXT_PUBLIC_OPENOBSERVE_RUM_VERSION=
NEXT_PUBLIC_OPENOBSERVE_RUM_ORG=default
NEXT_PUBLIC_OPENOBSERVE_RUM_INSECURE_HTTP=false
NEXT_PUBLIC_OPENOBSERVE_RUM_API_VERSION=v1
NEXT_PUBLIC_OPENOBSERVE_RUM_SESSION_SAMPLE_RATE=100
NEXT_PUBLIC_OPENOBSERVE_RUM_REPLAY_SAMPLE_RATE=0
NEXT_PUBLIC_OPENOBSERVE_RUM_SESSION_REPLAY_ENABLED=false
NEXT_PUBLIC_OPENOBSERVE_RUM_PRIVACY_LEVEL=mask-user-input

# ── PHI field encryption ──────────────────────────────────────────────────────
# Required for SSN and bank account encryption (AES-256-GCM, app-layer).
# Generate a key:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be a 64-character hex string (32 bytes) or 44-character base64 string.
# NEVER commit the real key. Store it in your secrets manager / Vercel env vars.
PROFILE_ENCRYPTION_KEY=

# Reverse proxy / production domain
DOMAIN=yourdomain.com
ACME_EMAIL=you@yourdomain.com   # used by Traefik to register Let's Encrypt certs
