# OpenObserve SMTP settings for email alert destinations.
# Copy to /etc/openobserve.env on the VPS, then restart the openobserve service.
#
# Hostinger mailboxes:
#   Host: smtp.hostinger.com
#   Preferred: port 465 with SSL/TLS
#   Alternate: port 587 with STARTTLS

ZO_SMTP_ENABLED=true
ZO_SMTP_HOST=smtp.hostinger.com
ZO_SMTP_PORT=465
ZO_SMTP_USER_NAME=blee@healthcompass.cloud
ZO_SMTP_PASSWORD=replace-with-mailbox-password
ZO_SMTP_FROM_EMAIL=no-reply@healthcompass.cloud
ZO_SMTP_REPLY_TO=blee@healthcompass.cloud
ZO_SMTP_ENCRYPTION=ssltls

# Alternate Hostinger STARTTLS configuration:
# ZO_SMTP_PORT=587
# ZO_SMTP_ENCRYPTION=starttls
