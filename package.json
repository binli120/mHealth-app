{
  "name": "mhealth-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:check": "DATABASE_URL_DEV=${DATABASE_URL_DEV:-postgresql://postgres:postgres@localhost:54322/postgres} node ./scripts/check-db.mjs",
    "db:migrate:dev": "bash ./scripts/db-migrate-dev.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report e2e/report",
    "demo": "DEMO_MODE=true playwright test e2e/tests/demo-full-tour.spec.ts --project=chromium",
    "demo:prescreener": "DEMO_MODE=true playwright test e2e/tests/03-prescreener.spec.ts --project=chromium",
    "demo:benefit-stack": "DEMO_MODE=true playwright test e2e/tests/05-benefit-stack.spec.ts --project=chromium",
    "demo:appeal": "DEMO_MODE=true playwright test e2e/tests/07-appeal-assistant.spec.ts --project=chromium",
    "demo:auth": "DEMO_MODE=true playwright test e2e/tests/02-auth.spec.ts --project=chromium",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "stack": "pnpm lint && pnpm test && pnpm run build-storybook && pnpm dev"
  },
